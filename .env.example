# ─────────────────────────────────────────────────────────────
# ML Blogger Automation System — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Blogger / Google OAuth2 credentials ──────────────────────
# See README.md → "Setting Up Blogger API Credentials" for how to get these.

BLOGGER_BLOG_ID=your_blog_id_here
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

# Optional: legacy API key (not used for posting, only for public read)
# BLOGGER_API_KEY=your_api_key

# ── Groq LLM content enrichment ──────────────────────────────
# Groq gives you fast free inference via llama3-8b-8192.
# Set USE_LLM=true and add your key to enable richer prose.
# Leave USE_LLM=false to use the built-in template writer (works offline).
USE_LLM=true
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Publish behavior ──────────────────────────────────────────
# DRY_RUN=true → runs the full pipeline but does NOT call Blogger API
DRY_RUN=false

# DRAFT_MODE=true → publishes to Blogger as draft (not visible publicly)
DRAFT_MODE=false

# ── File paths ────────────────────────────────────────────────
TOPICS_FILE=topics/topics.json
LOG_DIR=logs

# ── Author ────────────────────────────────────────────────────
AUTHOR_NAME=Mukesh

# ── Pexels featured image ─────────────────────────────────────
# Get your free API key at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here
PEXELS_PER_PAGE=10
RETRY_DELAY_SECONDS=5
